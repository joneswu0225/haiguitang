{
  "version": 2,
  "build": {
    "env": {
      "PIP_BREAK_SYSTEM_PACKAGES": "1"
    }
  },
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/app/app.py",
      "use": "@vercel/python@3.12"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/app/app.py" },
    { "src": "/(.*)", "dest": "/frontend/dist/index.html" }
  ]
}